generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  status      String
  createdAt   DateTime @default(now())

  tasks        Task[]
  risks        Risk[]
  decisions    Decision[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  status      String
  assignedTo  String?
  deadline    String?

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
}

model Risk {
  id          Int      @id @default(autoincrement())
  riskType    String
  severity    String

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
}

model Decision {
  id          Int      @id @default(autoincrement())
  action      String
  reason      String

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
}
